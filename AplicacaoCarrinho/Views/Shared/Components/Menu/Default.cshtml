@inject AppLayoutAspCore.Libraries.Login.LoginCliente _LoginCliente

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Loja Virtual</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/carousel/carousel.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-ecommerce-uikit/css/ui.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-ecommerce-uikit/css/responsive.css" media="only screen and (max-width: ...)" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AppLayoutAspCore.styles.css" asp-append-version="true" />

    <link rel="stylesheet"
          href="https://use.fontawesome.com/releases/v5.6.3/css/all.css"
          integrity="sha384-UHRtZLI+pbxtHCWp1t77Bi1L4Ztiq"
          crossorigin="anonymous">
</head>
<body>

    <header>
        @await Component.InvokeAsync("Menu")
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script src="~/lib/holder/holder.min.js"></script>
    <script src="~/lib/jquery/jquery-3.3.1.min.js"></script>

</body>
</html>
